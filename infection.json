{
    "$schema": "https://infection.github.io/schema/infection-schema.json",
    "source": {
        "directories": ["src"],
        "excludes": ["Language", "Helpers"]
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testsuite Unit,Integration",
    "minMsi": 60,
    "minCoveredMsi": 70,
    "logs": {
        "text": "infection.log",
        "summary": "infection-summary.log"
    },
    "mutators": { "@default": true }
}
