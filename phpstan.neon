parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - vendor
    ignoreErrors:
        # Config\Database lives in each consumer app's app/Config/, not in the
        # CI4 framework. PHPStan can't resolve it from the package side, but
        # the symbol is guaranteed at runtime in any CI4 host.
        -
            message: '#unknown class Config\\Database#'
            path: src/Validators/ForeignKeyValidator.php

        # APPPATH and ROOTPATH are CI4 framework runtime constants. PHPStan
        # doesn't see them when analyzing the package in isolation; in any
        # CI4 host (and in tests/bootstrap.php) they're always defined.
        -
            message: '#Constant (APPPATH|ROOTPATH) not found#'
            paths:
                - src/Generators/*
                - src/Orchestration/*
                - src/Wiring/*
                - src/Commands/*

        # EXIT_SUCCESS and EXIT_ERROR are spark command convention constants
        # defined by CI4 when commands run.
        -
            message: '#Constant EXIT_(SUCCESS|ERROR) not found#'
            paths:
                - src/Commands/*

        # config() is a CI4 global helper (system/Common.php). It's loaded by
        # the framework on every request/command but PHPStan doesn't see it
        # without bootstrapping the full framework.
        -
            message: '#Function config not found#'
            paths:
                - src/Commands/*

        # CLI::prompt() returns string|bool (bool when stdin is not a TTY).
        # The `=== null` defensive check is intentional, inherited from the
        # original ci4-api-starter implementation. PHPStan reads only the
        # string return type and complains.
        -
            message: '#Strict comparison using === between string and null will always evaluate to false#'
            path: src/Commands/MakeCrud.php
