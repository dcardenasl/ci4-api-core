parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - vendor
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Config\Database / Config\Services / Config\App live in each consumer
        # app/Config/, not in the CI4 framework. PHPStan can't resolve them
        # from the package side, but the symbols are guaranteed at runtime.
        -
            message: '#(unknown class|Class) Config\\(Database|Services|App|Cors|Api|FeatureFlags|Queue|Audit)( not found\.)?#'
            paths:
                - src/Http/*
                - src/Models/*
                - src/Services/*
                - src/Support/*
                - src/Logging/*
                - src/Monitoring/*
                - src/Queue/*
                - src/Dto/*
                - src/Commands/*

        # CoreCheck, CoreInstall and ServiceFactoriesValidator inspect consumer
        # Config\Services for factory methods at runtime. PHPStan knows the class
        # doesn't exist in this package so method_exists() appears to always
        # return false — suppress this expected false positive.
        -
            identifier: function.impossibleType
            path: src/Commands/CoreCheck.php
        -
            identifier: function.impossibleType
            path: src/Commands/CoreInstall.php
        -
            identifier: function.impossibleType
            path: src/Support/ServiceFactoriesValidator.php

        # Config\* method/property access on unknown classes.
        -
            message: '#(method|property|Access to property) [^ ]+ on an unknown class Config\\(Cors|Api|FeatureFlags|App|Queue|Audit)#'
            paths:
                - src/Http/*
                - src/Logging/*
                - src/Monitoring/*
                - src/Queue/*
                - src/Services/Audit/*

        # has invalid type Config\X parameter type-hints.
        -
            message: '#has invalid type Config\\(Cors|Api|FeatureFlags|App|Queue|Audit)#'
            paths:
                - src/Http/*
                - src/Logging/*
                - src/Monitoring/*
                - src/Queue/*
                - src/Services/Audit/*

        # QueueManager works with stdClass-shaped DB rows — columns exist at
        # runtime in the consumer's `jobs` table migration.
        -
            identifier: property.notFound
            path: src/Queue/QueueManager.php

        # CI4 FilterInterface ships untyped `array $arguments`.
        -
            identifier: missingType.iterableValue
            paths:
                - src/Http/Filters/*

        # Procedural date helper accepts generic `array` parameters.
        -
            identifier: missingType.iterableValue
            paths:
                - src/Helpers/*

        # Sentry is an optional integration in MonologHandler.
        -
            message: '#(class|Function) Sentry\\#'
            path: src/Logging/MonologHandler.php
        -
            message: '#Instantiated class Sentry\\Monolog\\Handler not found#'
            path: src/Logging/MonologHandler.php
        -
            message: '#expects Monolog\\Handler\\HandlerInterface, Sentry\\Monolog\\Handler given#'
            path: src/Logging/MonologHandler.php

        # ApiRequest extends IncomingRequest which requires Config\App.
        -
            message: '#Parameter \$config of method dcardenasl\\Ci4ApiCore\\Http\\ApiRequest\:\:__construct\(\) has invalid type Config\\App#'
            path: src/Http/ApiRequest.php

        # ApiController instanceof guards are intentional defensive checks.
        -
            identifier: instanceof.alwaysTrue
            path: src/Http/ApiController.php

        # Public-API traits consumed by models/services in consumer projects.
        -
            identifier: trait.unused
            paths:
                - src/Models/Traits/Filterable.php
                - src/Models/Traits/Searchable.php
                - src/Models/Traits/AppliesQueryOptions.php
                - src/Support/ResolvesWebAppLinks.php

        # DtoResponseMapper does defensive instanceof checks on reflection results.
        -
            identifier: instanceof.alwaysTrue
            path: src/Mappers/DtoResponseMapper.php

        # RelationLabelLoader queries opaque CI4 row objects — properties exist
        # at runtime but PHPStan cannot infer them statically.
        -
            identifier: property.notFound
            path: src/Support/RelationLabelLoader.php

        # CI4 global helpers (lang, service, log_message, config, env).
        -
            message: '#Function (lang|service|log_message|config) not found#'
            paths:
                - src/*
        -
            message: '#Function env not found#'
            paths:
                - src/*

        # ENVIRONMENT is a CI4 framework runtime constant.
        -
            message: '#Constant ENVIRONMENT not found#'
            paths:
                - src/Config/*
                - src/Support/ExceptionFormatter.php
                - src/Http/ApiController.php
                - src/Logging/*
                - src/Monitoring/*
                - src/Http/Filters/*

        # WRITEPATH is a CI4 framework runtime path constant.
        -
            message: '#Constant WRITEPATH not found#'
            paths:
                - src/Logging/*
                - src/Monitoring/*

        # APPPATH is a CI4 framework runtime path constant used by install commands.
        -
            message: '#Constant APPPATH not found#'
            paths:
                - src/Commands/*
