{
  "name": "dcardenasl/ci4-api-core",
  "description": "DTO-first API runtime foundation for CodeIgniter 4: base classes, HTTP layer, services, repositories, filters, audit chain, and queue. Powers ci4-api-starter and ci4-domain-starter. Pair with dcardenasl/ci4-api-scaffolding for CRUD generation.",
  "type": "library",
  "keywords": [
    "codeigniter4",
    "api",
    "dto",
    "rest",
    "foundation",
    "base-classes"
  ],
  "homepage": "https://github.com/dcardenasl/ci4-api-core",
  "license": "MIT",
  "authors": [
    {
      "name": "David Cárdenas L.",
      "email": "code.dcl@gmail.com"
    }
  ],
  "support": {
    "issues": "https://github.com/dcardenasl/ci4-api-core/issues",
    "source": "https://github.com/dcardenasl/ci4-api-core"
  },
  "require": {
    "php": "^8.2",
    "codeigniter4/framework": "^4.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.95",
    "monolog/monolog": "^3.5",
    "zircote/swagger-php": "^4.10 || ^5.0 || ^6.0",
    "spatie/phpunit-snapshot-assertions": "^5.0"
  },
  "suggest": {
    "monolog/monolog": "Required for JSON structured logging via JsonFormatter / MonologHandler (^3.5)",
    "zircote/swagger-php": "Required to auto-generate OpenAPI specs from DTO/Controller annotations (^4.10 || ^5.0 || ^6.0)",
    "ext-redis": "Required to use RedisQueueManager as an alternative to the DB-backed QueueManager"
  },
  "autoload": {
    "psr-4": {
      "dcardenasl\\Ci4ApiCore\\": "src/"
    },
    "files": [
      "src/Helpers/date.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --level=8 --memory-limit=1G",
    "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff --no-interaction",
    "cs-fix": "vendor/bin/php-cs-fixer fix --no-interaction",
    "security": "composer audit --no-dev --locked",
    "quality": [
      "@analyse",
      "@cs-check",
      "@security",
      "@test"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "codeigniter4": {
      "commands": [
        "dcardenasl\\Ci4ApiCore\\Commands\\CoreCheck",
        "dcardenasl\\Ci4ApiCore\\Commands\\CoreInstall"
      ]
    },
    "branch-alias": {
      "dev-main": "0.3.x-dev"
    }
  }
}
